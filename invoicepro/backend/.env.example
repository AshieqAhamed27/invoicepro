PORT=5000
MONGO_URI=mongodb://localhost:27017/invoicepro
JWT_SECRET=your_super_secret_jwt_key_change_this
FRONTEND_URL=http://localhost:5173
# Comma-separated origins for deployed frontends.
# Supports exact origins and wildcard patterns such as https://invoicepro-*.vercel.app
CORS_ORIGINS=http://localhost:5173
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_MONTHLY_PLAN_ID=plan_your_monthly_subscription_plan_id
RAZORPAY_YEARLY_PLAN_ID=plan_your_yearly_subscription_plan_id
# Fallback display price in rupees. Live mode fetches the real amount from Razorpay plan IDs when possible.
PRO_MONTHLY_AMOUNT=499
PRO_YEARLY_AMOUNT=4999
# Set true locally when Razorpay keys are not ready, so Pro upgrades can be tested end-to-end.
PAYMENT_SIMULATION=true
# Optional. When configured, AI drafting uses OpenAI; otherwise InvoicePro uses local fallback rules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM_NAME=InvoicePro
EMAIL_FROM=your_email@gmail.com
CRON_SECRET=change_this_to_a_long_random_string
