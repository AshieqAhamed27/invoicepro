PORT=5000
MONGO_URI=mongodb://localhost:27017/invoicepro
JWT_SECRET=your_super_secret_jwt_key_change_this
FRONTEND_URL=http://localhost:5173
# Comma-separated origins for deployed frontends.
# Supports exact origins and wildcard patterns such as https://invoicepro-*.vercel.app
CORS_ORIGINS=http://localhost:5173
# Required if Google login is enabled in the frontend.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# Optional abuse protection overrides. Defaults are safe for normal SaaS usage.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX=80
PAYMENT_RATE_LIMIT_WINDOW_MS=900000
PAYMENT_RATE_LIMIT_MAX=80
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_MONTHLY_PLAN_ID=plan_your_monthly_subscription_plan_id
RAZORPAY_YEARLY_PLAN_ID=plan_your_yearly_subscription_plan_id
# Fallback display price in rupees. Live mode fetches the real amount from Razorpay plan IDs when possible.
PRO_MONTHLY_AMOUNT=499
PRO_YEARLY_AMOUNT=4999
FOUNDER_90_AMOUNT=999
# Optional one-time agency setup package prices in rupees.
AGENCY_STARTER_AMOUNT=999
AGENCY_GROWTH_AMOUNT=2999
AGENCY_MANAGED_AMOUNT=4999
# Set true locally when Razorpay keys are not ready, so Pro upgrades can be tested end-to-end.
PAYMENT_SIMULATION=true
# Optional. When configured, AI drafting uses OpenAI; otherwise InvoicePro uses local fallback rules.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM_NAME=InvoicePro
EMAIL_FROM=your_email@gmail.com
# Recommended for production email on Render. If present, Resend is used instead of Gmail SMTP.
RESEND_API_KEY=
RESEND_FROM=InvoicePro <onboarding@resend.dev>
CRON_SECRET=change_this_to_a_long_random_string
# Optional Docker sandbox for Team Workspace Code Arena.
# Keep false on normal Render/Vercel deployments. Enable only on a server with Docker access.
CODE_RUNNER_ENABLED=false
CODE_RUNNER_TIMEOUT_MS=5000
CODE_RUNNER_MEMORY=128m
CODE_RUNNER_CPUS=0.5
CODE_RUNNER_MAX_CODE_BYTES=40000
CODE_RUNNER_MAX_OUTPUT_BYTES=12000
# Used when the backend container controls Docker through /var/run/docker.sock.
CODE_RUNNER_SHARED_VOLUME=clientflow-code-runner-workspaces
CODE_RUNNER_WORKDIR=/runner-workspaces
